{
  "name": "sense-hat",
  "version": "0.0.0",
  "description": "Sense HAT Dashboard",
  "author": "eHealth Africa",
  "license": "Apache-2.0",
  "scripts": {
    "lint": "eslint --quiet hat/assets/js/",
    "fix-lint": "eslint --quiet --fix hat/assets/js/ --config hat/assets/js/.eslintrc.json",
    "mocha": "mocha --require ./hat/assets/js/test/mocha.setup.js './hat/assets/js/**/*.spec.js'",
    "mocha-watch": "mocha --require ./hat/assets/js/test/mocha.setup.js './hat/assets/js/**/*.spec.js' --watch",
    "test": "npm run lint && npm run mocha",
    "build": "npm run webpack",
    "webpack": "webpack --config ./hat/webpack.dev.js",
    "webpack-prod": "webpack --config ./hat/webpack.prod.js",
    "extract-strings": "node ./build_scripts/merge-js-transifex.js",
    "webpack-server": "node ./hat/webpack.server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eHealthAfrica/sense-hat.git"
  },
  "bugs": {
    "url": "https://github.com/eHealthAfrica/sense-hat/issues"
  },
  "homepage": "https://github.com/eHealthAfrica/sense-hat#readme",
  "devDependencies": {
    "leaflet-draw": "^1.0.4",
    "react-beautiful-dnd": "^11.0.4",
    "react-color": "^2.17.3",
    "webpack-cli": "^3.3.5"
  },
  "standard": {
    "ignore": [
      "hat/assets/bundles",
      "hat/dashboard/static/docs"
    ]
  },
  "dependencies": {
    "@babel/core": "^7.0.1",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
