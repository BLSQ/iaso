{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "Schema for Sence HAT mobile data",
  "type": "object",
  "required": ["type", "dateCreated", "dateModified", "_id"],
  "properties": {
    "type": { "enum": ["participant"] },
    "dateCreated": { "type": "string", "format": "date-time" },
    "dateModified": { "type": "string", "format": "date-time" },
    "_id": { "type": "string", "format": "uuid" },
    "_rev": { "type": "string", "format": "uuid" },
    "person": { "$ref": "#/definitions/person" },
    "participant": { "$ref": "#/definitions/participant" }
  },
  "definitions": {
    "person": {
      "type": "object",
      "required": ["forename", "surname", "birthYear", "location"],
      "properties": {
        "forename": { "type": "string", "format": "name" },
        "surname": { "type": "string", "format": "name" },
        "postname": { "type": "string", "format": "name" },
        "gender": { "enum": ["Female", "Male"] },
        "birthYear": { "type": "integer", "minimum": 1900 },
        "mothersSurname": { "type": "string", "format": "name" },
        "location": { "$ref": "#/definitions/location" },
        "age": {
          "type": "object",
          "properties": {
            "years": { "type": "string", "format": "str-years" },
            "months": { "type": "string", "format": "str-months" }
          }
        }
      }
    },
    "participant": {
      "type": "object",
      "required": ["hatId", "screeningLocation"],
      "properties": {
        "version": { "type": "integer" },
        "hatId": { "type": "string" },
        "memberType": { "enum": ["traveller", "resident"] },
        "screeningLocation": { "$ref": "#/definitions/location" },
        "screenings": {
          "type": "object",
          "properties": {
            "rdt": { "$ref": "#/definitions/test" },
            "catt": { "$ref": "#/definitions/test" },
            "pg": { "$ref": "#/definitions/test" },
            "maect": { "$ref": "#/definitions/test" },
            "ctcwoo": { "$ref": "#/definitions/test" },
            "ge": { "$ref": "#/definitions/test" },
            "pl": { "$ref": "#/definitions/test" }
          }
        },
        "geoLocation": { "$ref": "#/definitions/geoLocation" }
      }
    },
    "test": {
      "type": "object",
      "properties": {
        "sessionType": { "enum": ["doorToDoor", "onTheSpot"] },
        "result": { "enum": ["negative", "positive"] },
        "group": { "type": "string", "format": "date-time" }
      }
    },
    "location": {
      "type": "object",
      "properties": {
        "zone": { "type": "string", "format": "location-zone" },
        "area": { "type": "string", "format": "location-area" },
        "village": { "type": "string", "format": "location-village" }
      }
    },
    "geoLocation": {
      "type": "object",
      "properties": {
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      }
    }
  }
}
