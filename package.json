{
  "name": "sense-hat",
  "version": "0.0.0",
  "description": "Sense HAT",
  "main": "index.js",
  "scripts": {
    "lint": "standard",
    "mocha": "mocha --require ./hat/assets/js/test/mocha.setup.js ./hat/assets/js/**/*.spec.js",
    "test": "npm run lint && npm run mocha",
    "build": "npm run webpack && npm run extract-strings",
    "webpack": "webpack --config ./hat/webpack.prod.js",
    "extract-strings": "node ./build_scripts/merge-js-transifex.js",
    "webpack-server": "node ./hat/webpack.server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eHealthAfrica/sense-hat.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/eHealthAfrica/sense-hat/issues"
  },
  "homepage": "https://github.com/eHealthAfrica/sense-hat#readme",
  "dependencies": {
    "couchdb-bootstrap": "^1.14.0",
    "node-jose": "^0.9.0"
  },
  "standard": {
    "ignore": [
      "hat/assets/bundles",
      "couchdb/"
    ]
  },
  "devDependencies": {
    "babel-core": "^6.13.2",
    "babel-loader": "^6.2.5",
    "babel-plugin-react-intl": "^2.1.4",
    "babel-preset-es2015": "^6.13.2",
    "babel-preset-react": "^6.11.1",
    "babel-preset-stage-2": "^6.13.0",
    "babel-register": "^6.14.0",
    "css-loader": "^0.24.0",
    "extract-text-webpack-plugin": "^1.0.1",
    "file-loader": "^0.9.0",
    "font-awesome": "^4.6.3",
    "history": "^2.1.2",
    "jsdom": "^9.4.2",
    "json-loader": "^0.5.4",
    "mocha": "^3.0.2",
    "node-sass": "^3.8.0",
    "react": "^15.3.1",
    "react-addons-test-utils": "^15.3.1",
    "react-dom": "^15.3.1",
    "react-hot-loader": "^1.3.0",
    "react-intl": "^2.1.4",
    "react-redux": "^4.4.5",
    "react-router": "^2.7.0",
    "react-router-redux": "^4.0.5",
    "recursive-readdir": "^2.0.0",
    "redux": "^3.5.2",
    "sass-loader": "^4.0.0",
    "standard": "^8.0.0",
    "style-loader": "^0.13.1",
    "superagent": "^2.3.0",
    "url-loader": "^0.5.7",
    "vega": "^2.6.0",
    "vega-lite": "^1.2.0",
    "webpack": "^1.13.2",
    "webpack-bundle-tracker": "0.0.93",
    "webpack-dev-server": "^1.15.0"
  }
}
