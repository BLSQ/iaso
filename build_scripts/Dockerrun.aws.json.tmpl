{
  "AWSEBDockerrunVersion": 2,
  "volumes": [
    {
      "name": "logstash-conf",
      "host": {
        "sourcePath": "/etc/logstash"
      }
    },
    {
      "name": "sense-shared",
      "host": {
        "sourcePath": "/opt/shared"
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "logstash",
      "image": "387526361725.dkr.ecr.us-east-1.amazonaws.com/logstash:latest",
      "entryPoint": ["logstash", "agent", "-f", "/src/logstash.conf"],
      "essential": true,
      "memory": 512,
      "mountPoints": [
      {
        "sourceVolume": "logstash-conf",
        "containerPath": "/src/",
        "readOnly": true
      }
      ],
        "portMappings": [
        {
          "hostPort": 5044,
          "containerPort": 5044
        }
      ]
    },
    {
      "name": "sense-web",
      "image": "387526361725.dkr.ecr.eu-west-1.amazonaws.com/hat-historical:${TAG}",
      "essential": true,
      "memory": 512,
      "hostname": "sense-web",
      "command": [ "start" ],
      "portMappings": [
        {
          "hostPort": 80,
          "containerPort": 80
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "sense-shared",
          "containerPath": "/opt/shared",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "syslog",
        "options":{
          "syslog-address": "tcp://localhost:5044",
          "tag": "sense-web"
        }
      },
      "links": [
        "redis"
      ]
    },
    {
      "name": "redis",
      "image": "redis:3.2",
      "essential": true,
      "memory": 512,
      "hostname": "redis",
      "logConfiguration": {
        "logDriver": "syslog",
        "options":{
          "syslog-address": "tcp://localhost:5044",
          "tag": "sense-redis"
        }
      }
    },
    {
      "name": "sense-rq",
      "image": "387526361725.dkr.ecr.eu-west-1.amazonaws.com/hat-historical:${TAG}",
      "essential": true,
      "memory": 512,
      "hostname": "sense-rq",
      "command": [ "start_rq" ],
      "mountPoints": [
        {
          "sourceVolume": "sense-shared",
          "containerPath": "/opt/shared",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "syslog",
        "options":{
          "syslog-address": "tcp://localhost:5044",
          "tag": "sense-rq"
        }
      },
      "links": [
        "redis"
      ]
    }
  ]
}
