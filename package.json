    "babel-polyfill": "^6.26.0",
    "babel-register": "^6.26.0",
    "color": "^3.1.2",
    "css-loader": "^3.0.0",
    "eslint-config-airbnb": "^17.1.1",
    "eslint-loader": "^2.1.2",
    "eslint-plugin-jsx-a11y": "^6.2.3",
    "eslint-plugin-react": "^7.14.2",
    "fetch-mock": "^7.3.3",
    "file-loader": "^4.0.0",
    "font-awesome": "^4.7.0",
    "husky": "^3.0.0",
