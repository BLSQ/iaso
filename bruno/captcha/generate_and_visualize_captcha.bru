meta {
  name: generate_and_visualize_captcha
  type: http
  seq: 2
}

get {
  url: {{HOST}}/api/captcha/image/{{captcha_key}}/
  body: none
  auth: none
}

script:pre-request {
  const response = await bru.runRequest("captcha/generate_captcha");
  bru.setVar("captcha_key", response.data.key);
}

settings {
  encodeUrl: true
  timeout: 0
}
