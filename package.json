{
  "name": "sense-hat",
  "version": "0.0.0",
  "description": "Sense HAT",
  "main": "index.js",
  "scripts": {
    "lint": "standard",
    "mocha": "mocha --require ./hat/assets/js/test/mocha.setup.js './hat/assets/js/**/*.spec.js'",
    "test": "npm run lint && npm run mocha",
    "build": "npm run webpack && npm run extract-strings",
    "webpack": "webpack --config ./hat/webpack.prod.js",
    "extract-strings": "node ./build_scripts/merge-js-transifex.js",
    "webpack-server": "node ./hat/webpack.server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eHealthAfrica/sense-hat.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/eHealthAfrica/sense-hat/issues"
  },
  "homepage": "https://github.com/eHealthAfrica/sense-hat#readme",
  "dependencies": {
    "node-jose": "~0.9.0"
  },
  "standard": {
    "ignore": [
      "hat/assets/bundles",
      "couchdb/"
    ]
  },
  "devDependencies": {
    "babel-core": "~6.24.0",
    "babel-loader": "~6.4.0",
    "babel-plugin-react-intl": "~2.3.0",
    "babel-preset-es2015": "~6.24.0",
    "babel-preset-react": "~6.23.0",
    "babel-preset-stage-2": "~6.22.0",
    "babel-register": "~6.24.0",
    "css-loader": "~0.27.0",
    "eslint-plugin-react": "~6.10.0",
    "extract-text-webpack-plugin": "~2.1.0",
    "fetch-mock": "~5.9.0",
    "file-loader": "~0.10.0",
    "font-awesome": "~4.7.0",
    "jquery": "~3.2.0",
    "jsdom": "~9.12.0",
    "json-loader": "~0.5.0",
    "leaflet": "~1.0.0",
    "metrics-graphics": "~2.11.0",
    "mocha": "~3.2.0",
    "nock": "~9.0.0",
    "node-sass": "~4.5.0",
    "react": "~15.4.0",
    "react-addons-test-utils": "~15.4.0",
    "react-datepicker": "~0.43.0",
    "react-dom": "~15.4.0",
    "react-hot-loader": "~3.0.0-beta.6",
    "react-intl": "~2.2.0",
    "react-redux": "~5.0.0",
    "react-router": "~3.0.0",
    "react-router-redux": "~4.0.0",
    "react-select": "~1.0.0-rc.3",
    "recursive-readdir": "~2.1.0",
    "redux": "~3.6.0",
    "sass-loader": "~6.0.0",
    "sinon": "~2.1.0",
    "standard": "~9.0.0",
    "style-loader": "~0.15.0",
    "superagent": "~3.5.0",
    "url-loader": "~0.5.0",
    "vega": "~2.6.0",
    "vega-lite": "~1.3.0",
    "webpack": "~2.3.0",
    "webpack-bundle-tracker": "~0.2.0",
    "webpack-dev-server": "~2.4.0",
    "xlsx": "~0.9.0"
  }
}
