{
  "name": "sense-hat",
  "version": "0.0.0",
  "description": "Sense HAT Dashboard",
  "author": "eHealth Africa",
  "license": "Apache-2.0",
  "scripts": {
    "lint": "eslint --quiet hat/assets/js/",
    "mocha": "mocha --require ./hat/assets/js/test/mocha.setup.js './hat/assets/js/**/*.spec.js'",
    "mocha-watch": "mocha --require ./hat/assets/js/test/mocha.setup.js './hat/assets/js/**/*.spec.js' --watch",
    "test": "npm run lint && npm run mocha",
    "build": "npm run webpack",
    "webpack": "webpack --config ./hat/webpack.dev.js",
    "webpack-prod": "webpack --config ./hat/webpack.prod.js",
    "extract-strings": "node ./build_scripts/merge-js-transifex.js",
    "webpack-server": "node ./hat/webpack.server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eHealthAfrica/sense-hat.git"
  },
  "bugs": {
    "url": "https://github.com/eHealthAfrica/sense-hat/issues"
  },
  "homepage": "https://github.com/eHealthAfrica/sense-hat#readme",
  "devDependencies": {
    "babel-core": "~6.26.0",
    "babel-eslint": "^8.2.1",
    "babel-loader": "~7.1.2",
    "babel-plugin-react-intl": "~2.4.0",
    "babel-polyfill": "^6.26.0",
    "babel-preset-es2015": "~6.24.0",
    "babel-preset-react": "^6.24.1",
    "babel-preset-stage-2": "~6.24.0",
    "babel-register": "~6.26.0",
    "css-loader": "~0.28.0",
    "eslint-config-airbnb": "^16.1.0",
    "eslint-loader": "^2.0.0",
    "eslint-plugin-jsx-a11y": "^6.0.3",
    "eslint-plugin-react": "^7.6.1",
    "extract-text-webpack-plugin": "~3.0.2",
    "fetch-mock": "~6.0.0",
    "file-loader": "~1.1.7",
    "font-awesome": "~4.7.0",
    "jquery": "~3.3.1",
    "jsdom": "~11.6.2",
    "json-loader": "~0.5.0",
    "leaflet": "~1.3.3",
    "leaflet.markercluster": "^1.3.0",
    "metrics-graphics": "~2.13.0",
    "mocha": "~5.0.1",
    "moment": "^2.20.1",
    "nock": "~9.1.6",
    "node-jose": "~0.11.0",
    "node-sass": "~4.7.2",
    "prop-types": "~15.6.0",
    "react": "~16.4.2",
    "react-addons-test-utils": "~15.6.2",
    "react-datepicker": "~1.2.1",
    "react-dom": "~16.4.2",
    "react-hot-loader": "~3.1.3",
    "react-intl": "~2.4.0",
