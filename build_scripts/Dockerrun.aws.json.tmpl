{
  "AWSEBDockerrunVersion": 2,
  "volumes": [
    {
      "name": "historical-shared",
      "host": {
        "sourcePath": "/opt/shared"
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "historical-web",
      "image": "387526361725.dkr.ecr.eu-west-1.amazonaws.com/hat-historical:${TAG}",
      "essential": true,
      "memory": 512,
      "hostname": "historical-web",
      "command": [ "start" ],
      "portMappings": [
        {
          "hostPort": 80,
          "containerPort": 80
        },
        {
          "hostPort": 443,
          "containerPort": 80
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "historical-shared",
          "containerPath": "/opt/shared",
          "readOnly": false
        }
      ],
      "links": [
        "redis"
      ]
    },
    {
      "name": "redis",
      "image": "redis:3.2",
      "essential": true,
      "memory": 512,
      "hostname": "redis"
    },
    {
      "name": "historical-rq",
      "image": "387526361725.dkr.ecr.eu-west-1.amazonaws.com/hat-historical:${TAG}",
      "essential": true,
      "memory": 512,
      "hostname": "historical-rq",
      "command": [ "start_rq" ],
      "mountPoints": [
        {
          "sourceVolume": "historical-shared",
          "containerPath": "/opt/shared",
          "readOnly": false
        }
      ],
      "links": [
        "redis"
      ]
    }
  ]
}
