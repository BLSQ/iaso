    "react-redux": "^5.0.7",
    "react-router": "~3.0.0",
    "react-router-redux": "~4.0.0",
    "react-select": "~1.2.1",
    "react-switch": "^3.0.4",
    "react-table": "^6.8.0",
    "recursive-readdir": "~2.2.1",
    "redux": "~3.7.2",
    "sass-loader": "~6.0.0",
    "sinon": "~4.3.0",
    "standard": "~11.0.0",
    "style-loader": "~0.20.2",
    "superagent": "~3.8.2",
    "topojson": "~3.0.2",
    "url-loader": "~0.6.2",
    "vega": "~2.6.0",
    "vega-lite": "~1.3.0",
    "video.js": "^6.6.3",
